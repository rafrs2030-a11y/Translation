{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "translation-project",
  "compatibility_date": "2024-09-27",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "build": {
    "command": "npm run build:cloudflare",
    "cwd": "./"
  }
}
